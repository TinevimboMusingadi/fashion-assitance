# =============================================================================
# Dripcheck Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================================

# -- Gemini AI --
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -- Firebase Client SDK (public, safe to expose in browser) --
# Get these from: firebase apps:sdkconfig WEB --project=sinuous-wording-445121-f8
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# -- Firebase Admin / GCP (server-side only, NEVER expose to browser) --
# Option 1: Path to the service account key JSON file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=your_service_account_key_path_here
# Option 2: Full JSON string of the service account key (Vercel deployment)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...",...}

# -- GCP Project --
GCP_PROJECT_ID=sinuous-wording-445121-f8

# -- Cloud Storage Bucket Names --
GCS_BUCKET_WARDROBES=dripcheck-wardrobes
GCS_BUCKET_GENERATED=dripcheck-generated
GCS_BUCKET_PROFILES=dripcheck-profiles
